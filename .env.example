# WIBAWA NUSANTARA — Environment Variables Example Template
# Salin file ini menjadi `.env.local` untuk development lokal.

# 1. Supabase Settings
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_public_api_key_xxxxxxxx"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_secret_key_never_expose_to_client"

# 2. Midtrans Payment Gateway Configurations
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false
MIDTRANS_MERCHANT_ID="your_midtrans_merchant_id_Gxxxxxxxx"
MIDTRANS_SERVER_KEY="your_midtrans_server_key_SB-Mid-server-xxxxxxxx"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="your_midtrans_client_key_SB-Mid-client-xxxxxxxx"
MIDTRANS_NOTIFICATION_SECRET="your_midtrans_webhook_notification_secret"

# 3. Base Site URL Configurations
NEXT_PUBLIC_APP_URL="https://www.wibawa-nusantara.com"
NEXT_PUBLIC_SITE_URL="https://www.wibawa-nusantara.com"
NEXT_PUBLIC_LEGACY_UPLODAS_BASE_URL="https://www.wibawa-nusantara.com/uploads"